# =============================================================================
# .dockerignore (root level)
# Applies when docker-compose builds from the project root.
# =============================================================================

# Secrets — never allow these into ANY image
.env
*.env
!.env.example

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
LICENSE
docs/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.circleci/

# OS noise
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.suo
