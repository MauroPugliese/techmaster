# =============================================================================
# docker/mysql/conf/my.cnf
# Mounted at: /etc/mysql/conf.d/techmanager.cnf
# Overrides selected MySQL 8.0 defaults for a containerised workload.
# =============================================================================

[mysqld]

# ── Character set ─────────────────────────────────────────────────────────────
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ── Timezone ──────────────────────────────────────────────────────────────────
default-time-zone     = '+00:00'

# ── Connection & timeout ──────────────────────────────────────────────────────
max_connections       = 150
wait_timeout          = 28800
interactive_timeout   = 28800
connect_timeout       = 10

# ── InnoDB tuning (suitable for a 512 MB–1 GB container) ─────────────────────
innodb_buffer_pool_size       = 256M
innodb_log_file_size          = 64M
innodb_flush_log_at_trx_commit = 2   # slight perf gain; OK for dev/staging
innodb_flush_method            = O_DIRECT

# ── Query cache (disabled in MySQL 8+, left for clarity) ─────────────────────
# query_cache_type = 0

# ── Slow query log (useful for debugging in dev) ──────────────────────────────
slow_query_log         = 1
slow_query_log_file    = /var/log/mysql/slow.log
long_query_time        = 2

# ── Binary log (disable in dev to save I/O; enable for prod replication) ──────
skip-log-bin

# ── Disable strict mode for Sequelize compatibility ───────────────────────────
# Strict mode is kept ON; this just removes ONLY_FULL_GROUP_BY which can
# break some aggregate queries.
sql_mode = 'STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION'

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
